# ==============================================================================
# TELEGRAM BOT API - CONFIGURAÇÃO DO SERVIDOR LOCAL
# ==============================================================================

# --- CREDENCIAIS OFICIAIS ---
# Obtenha estas chaves registrando uma aplicação em: https://my.telegram.org/apps
TELEGRAM_API_ID=356562144
TELEGRAM_API_HASH=fb379c3b9sdg654g6ds486c82cc95acb1b

# --- INFRAESTRUTURA DOCKER (LINUX PERMISSIONS) ---
# PUID e PGID garantem que o container consiga escrever nas suas pastas locais
# no Ubuntu sem erros de 'Permission Denied'.
# Dica: No terminal, execute 'id -u' e 'id -g' para ver seus IDs (Geralmente 1000).
PUID=1000
PGID=1000

# Porta onde o servidor local ficará acessível
API_PORT=8081

# --- DIRETÓRIOS INTERNOS (OPCIONAL) ---
# Caminhos dentro do container. Recomenda-se manter o padrão.
TELEGRAM_WORK_DIR=/var/lib/telegram-bot-api
TELEGRAM_TEMP_DIR=/tmp/telegram-bot-api

# ==============================================================================
# CONFIGURAÇÕES DO BOT (main.go)
# ==============================================================================

# Token do Bot obtido via @BotFather
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# ID do Chat ou Canal para onde os vídeos serão enviados
CHAT_ID=-100123456789

# URL de conexão para o servidor local (utilizado pela lib go-telegram-bot-api)
# Como o bot e a API rodam no mesmo host, usamos 127.0.0.1
LOCAL_API_URL=http://127.0.0.1:8081